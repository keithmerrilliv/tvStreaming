{
  "name": "tv-streaming-tier-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Capability-tiering streaming demo: certified shell measures, server judges. Resolver + two-round handshake.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "typecheck:client": "tsc -p tsconfig.client.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "serve": "tsx server/server.ts",
    "demo": "tsx scripts/demo.ts",
    "build:client": "esbuild client/main.ts --bundle --format=iife --target=chrome53 --legal-comments=none --metafile=dist/meta.json --outfile=dist/app.js",
    "build": "npm run typecheck:client && npm run build:client"
  },
  "devDependencies": {
    "@types/node": "20.19.41",
    "esbuild": "0.28.0",
    "tsx": "4.22.3",
    "typescript": "5.9.3",
    "vitest": "4.1.7"
  },
  "dependencies": {
    "core-js": "3.49.0"
  }
}
