{
  "name": "tv-streaming-tier-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Capability-tiering streaming demo: certified shell measures, server judges. Resolver + two-round handshake.",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "typecheck:client": "tsc -p tsconfig.client.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "audit:prod": "node scripts/audit-prod.mjs",
    "serve": "tsx server/server.ts",
    "demo": "tsx scripts/demo.ts",
    "icons": "node scripts/generate-icons.mjs",
    "clean": "rm -rf dist",
    "build:client": "esbuild client/main.ts --bundle --format=iife --target=chrome53 --legal-comments=none --metafile=dist/meta.json --outfile=dist/webos/app.js",
    "build": "npm run clean && npm run typecheck:client && npm run build:client",
    "package:webos": "node scripts/package-webos.mjs",
    "package": "npm run build && npm run package:webos",
    "install:webos": "ares-install $(ls -t dist/*.ipk | head -1)",
    "launch:webos": "ares-launch com.example.tvstreaming"
  },
  "devDependencies": {
    "@types/node": "20.19.41",
    "@webosose/ares-cli": "2.4.0",
    "esbuild": "0.28.0",
    "tsx": "4.22.3",
    "typescript": "5.9.3",
    "vitest": "4.1.7"
  },
  "dependencies": {
    "core-js": "3.49.0"
  }
}
